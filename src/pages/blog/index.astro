---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			* {
					box-sizing: border-box;
					max-width: 100%;
				}
				body {
					overflow-x: hidden;
				}
			main {
				width: 100%;
				max-width: 640px;
				padding: 60px 24px 100px;
				flex: 1;
				min-width: 0;
			}
			.page-title {
				font-family: Georgia, serif;
				font-weight: 700;
				font-size: clamp(36px, 10vw, 64px);
				color: #1C1A17;
				margin-bottom: 50px;
			}
			ul {
				list-style: none;
				margin: 0;
				padding: 0;
			}
			li {
				margin-bottom: 40px;
				max-width: 100%;
				overflow: hidden;
			}
			li a {
				display: block;
				max-width: 100%;
			}
			.post-title {
				font-family: Georgia, serif;
				font-weight: 700;
				font-size: clamp(18px, 5vw, 24px);
				color: #1C1A17;
				text-decoration: underline;
				text-decoration-color: #1C1A17;
				text-decoration-thickness: 2px;
				text-underline-offset: 3px;
				margin: 0 0 12px;
				display: block;
				word-wrap: break-word;
				overflow-wrap: break-word;
			}
			.post-title:hover {
				color: #C5613A;
			}
			.post-desc {
				font-family: Georgia, serif;
				font-size: 16px;
				color: #3A3733;
				line-height: 1.6;
				margin: 0 0 14px;
			}
			.post-date {
				font-size: 12px;
				font-weight: 700;
				letter-spacing: 0.6px;
				text-transform: uppercase;
				color: #9A8C77;
			}
			.divider {
				height: 14px;
				margin: 36px 0 0;
				background-image: radial-gradient(circle at 5px 7px, transparent 5px, #C5613A 5.5px, #C5613A 6px, transparent 6.5px);
				background-size: 14px 14px;
				background-repeat: repeat-x;
				opacity: 0.6;
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<h1 class="page-title">Blog</h1>
			<ul>
				{
					posts.map((post, index) => (
						<li>
							<a href={`/blog/${post.id}/`}>
								<h2 class="post-title">{post.data.title}</h2>
							</a>
							<p class="post-desc">{post.data.description}</p>
							<p class="post-date">— <FormattedDate date={post.data.pubDate} /></p>
							{index < posts.length - 1 && <div class="divider" />}
						</li>
					))
				}
			</ul>
		</main>
		<Footer />
	</body>
</html>