---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<div class="hero">
				<div class="hero-left">
					<h1 class="h1">Welcome to Home Theory</h1>
					<p class="hbody">A friendly guide to Singapore property — check your eligibility, or learn how it all works.</p>
					<div class="btnrow">
						<a href="/quiz" class="btn quiz">
							<div class="b-title">Quiz</div>
							<div class="b-desc">Answer 6 quick questions and see exactly what you can buy, with grant estimates.</div>
						</a>
						<a href="/blog" class="btn blog">
							<div class="b-title">Blog</div>
							<div class="b-desc">Guides on BTO, resale, grants, and eligibility rules — explained in plain English.</div>
						</a>
					</div>
				</div>
				<div class="hero-right">
					<img src="/House-searching-pana.png" alt="Illustration of a person searching for a home" />
				</div>
			</div>
		</main>
		<Footer />
	</body>
</html>

<style>
	* {
		box-sizing: border-box;
	}
	main {
		width: 100%;
		max-width: 1200px;
		padding: 60px 40px;
		margin: 0 auto;
	}
	.hero {
		display: flex;
		align-items: center;
		gap: 60px;
	}
	.hero-left {
		flex: 1;
		max-width: 460px;
	}
	.h1 {
		font-family: Georgia, serif;
		font-size: clamp(34px, 4.5vw, 46px);
		font-weight: 700;
		color: #1C1A17;
		line-height: 1.15;
		margin: 0 0 20px;
	}
	.hbody {
		font-size: 16px;
		color: #5A5040;
		line-height: 1.6;
		margin: 0 0 24px;
	}
	.btnrow {
		display: flex;
		gap: 14px;
	}
	.btn {
		border-radius: 10px;
		padding: 18px 20px;
		width: 200px;
		text-decoration: none;
		display: block;
		transition: transform 0.15s;
	}
	.btn:hover {
		transform: translateY(-3px);
	}
	.btn.quiz {
		background: #C5613A;
	}
	.btn.blog {
		background: #6B4A32;
	}
	.b-title {
		font-family: Georgia, serif;
		font-size: 19px;
		font-weight: 700;
		color: #fff;
		margin-bottom: 6px;
	}
	.b-desc {
		font-size: 12px;
		color: rgba(255, 255, 255, 0.82);
		line-height: 1.5;
	}
	.hero-right {
		flex-shrink: 0;
		width: 480px;
	}
	.hero-right img {
		width: 100%;
		height: auto;
		object-fit: contain;
	}
	@media (max-width: 900px) {
		.hero {
			flex-direction: column-reverse;
			gap: 30px;
		}
		.hero-left {
			max-width: 100%;
		}
		.hero-right {
			width: 320px;
		}
	}
</style>