---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<div class="wrap">
				<div class="left">
					<div class="welcome">
						<h1 class="w-title">Welcome to Home Theory</h1>
						<p class="w-desc">A friendly guide to Singapore property — check your eligibility, or learn how it all works.</p>
					</div>
					<div class="btnrow">
						<a href="/quiz" class="btn quiz">
							<div class="b-title">Quiz</div>
							<div class="b-desc">Answer 6 quick questions and see exactly what you can buy, with grant estimates.</div>
						</a>
						<a href="/blog" class="btn blog">
							<div class="b-title">Blog</div>
							<div class="b-desc">Guides on BTO, resale, grants, and eligibility rules — explained in plain English.</div>
						</a>
					</div>
				</div>
				<div class="picture">
					<img src="/House-searching-pana.png" alt="Illustration of a person searching for a home" />
				</div>
			</div>
		</main>
		<Footer />
	</body>
</html>

<style>
main {
    width: 100%;
    max-width: 1500px;
    padding: 24px 60px 80px;
    min-height: calc(100vh - 200px);
    box-sizing: border-box;
}
	.wrap {
    display: flex;
    gap: 24px;
    align-items: flex-start;
	}
	.left {
		flex: 1.1;
		display: flex;
		flex-direction: column;
		gap: 16px;
		padding-top: 90px;
	}
	.welcome {
		padding: 4px 0;
	}
	.w-title {
		font-family: Georgia, serif;
		font-size: clamp(38px, 5vw, 48px);
		font-weight: 700;
		color: #1C1A17;
		margin: 0 0 14px;
		line-height: 1.15;
	}
	.w-desc {
		font-size: 14px;
		color: #7A6F5F;
		line-height: 1.6;
		margin: 0;
	}
	.btnrow {
		display: flex;
		gap: 14px;
	}
	.btn {
		flex: 1;
		border-radius: 12px;
		padding: 20px;
		text-decoration: none;
		display: flex;
		flex-direction: column;
		transition: transform 0.15s;
	}
	.btn:hover {
		transform: translateY(-3px);
	}
	.btn.quiz {
		background: #C5613A;
	}
	.btn.blog {
		background: #6B4A32;
	}
	.b-title {
		font-family: Georgia, serif;
		font-size: 22px;
		font-weight: 700;
		color: #fff;
		margin-bottom: 6px;
	}
	.b-desc {
		font-size: 12px;
		color: rgba(255, 255, 255, 0.82);
		line-height: 1.5;
	}
.picture {
    flex: 1;
    max-width: 480px;
    display: flex;
    align-items: flex-start;
    justify-content: center;
}
.picture img {
    width: 100%;
    height: auto;
    object-fit: contain;
}
	@media (max-width: 780px) {
		.wrap {
			flex-direction: column;
		}
		.left {
			padding-top: 0;
		}
		.picture {
			order: -1;
			margin-bottom: 20px;
			max-width: 100%;
		}
	}
</style>