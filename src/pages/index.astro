---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<div class="grid">
				<div class="welcome">
					<h1 class="w-title">Welcome to Home Theory</h1>
					<p class="w-desc">A friendly guide to Singapore property — check your eligibility, or learn how it all works.</p>
				</div>

				<a href="/quiz" class="btn quiz">
					<div class="b-title">Quiz</div>
					<div class="b-desc">Answer 6 quick questions and see exactly what you can buy, with grant estimates.</div>
				</a>

				<a href="/blog" class="btn blog">
					<div class="b-title">Blog</div>
					<div class="b-desc">Guides on BTO, resale, grants, and eligibility rules — explained in plain English.</div>
				</a>

				<div class="picture">
					<img src="/House-searching-pana.png" alt="Illustration of a person searching for a home" />
				</div>
			</div>
		</main>
		<Footer />
	</body>
</html>

<style>
	main {
		max-width: 1000px;
		padding: 40px 24px 80px;
	}
	.grid {
		display: grid;
		grid-template-columns: 1fr 1fr 1.1fr;
		grid-template-rows: auto 1fr;
		gap: 16px;
	}
	.welcome {
		grid-column: 1 / 3;
		padding: 10px 4px;
	}
	.w-title {
		font-family: Georgia, serif;
		font-size: clamp(32px, 5vw, 44px);
		font-weight: 700;
		color: #1C1A17;
		margin: 0 0 14px;
		line-height: 1.1;
	}
	.w-desc {
		font-size: 17px;
		color: #7A6F5F;
		line-height: 1.6;
		margin: 0;
	}
	.btn {
		border-radius: 12px;
		padding: 26px;
		text-decoration: none;
		display: flex;
		flex-direction: column;
		transition: transform 0.15s;
		min-height: 180px;
	}
	.btn:hover {
		transform: translateY(-3px);
	}
	.btn.quiz {
		background: #C5613A;
	}
	.btn.blog {
		background: #6B4A32;
	}
	.b-title {
		font-family: Georgia, serif;
		font-size: 30px;
		font-weight: 700;
		color: #fff;
		margin-bottom: 10px;
		height: 36px;
		display: flex;
		align-items: center;
	}
	.b-desc {
		font-size: 14px;
		color: rgba(255, 255, 255, 0.82);
		line-height: 1.55;
	}
	.picture {
		grid-column: 3 / 4;
		grid-row: 1 / 3;
		display: flex;
		align-items: center;
		justify-content: center;
		border-radius: 12px;
		overflow: hidden;
	}
	.picture img {
		width: 100%;
		height: auto;
		object-fit: contain;
	}
	@media (max-width: 780px) {
		.grid {
			grid-template-columns: 1fr;
			grid-template-rows: auto auto auto auto;
		}
		.welcome {
			grid-column: 1;
		}
		.picture {
			grid-column: 1;
			grid-row: auto;
			order: -1;
		}
	}
</style>