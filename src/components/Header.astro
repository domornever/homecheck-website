---
import HeaderLink from './HeaderLink.astro';
---

<link href="https://fonts.googleapis.com/css2?family=Fraunces:wght@700&display=swap" rel="stylesheet">

<header>
	<nav>
		<h2><a href="/" class="logo">Home <span>Theory</span></a></h2>
		<div class="internal-links" id="nav-links">
			<HeaderLink href="/">Home</HeaderLink>
			<HeaderLink href="/blog">Blog</HeaderLink>
			<HeaderLink href="/about">About</HeaderLink>
		</div>
		<div class="right-side">
			<a href="/quiz" class="eligibility-btn">Check my eligibility</a>
			<button class="menu-toggle" id="menu-toggle" aria-label="Toggle menu">☰</button>
		</div>
	</nav>
	<div class="mobile-links" id="mobile-links">
		<a href="/">Home</a>
		<a href="/blog">Blog</a>
		<a href="/about">About</a>
	</div>
</header>

<script>
	const toggle = document.getElementById('menu-toggle');
	const mobileLinks = document.getElementById('mobile-links');
	toggle?.addEventListener('click', () => {
		mobileLinks?.classList.toggle('open');
	});
</script>

<style>
	header {
		margin: 0;
		padding: 0 1em;
		background: white;
		box-shadow: 0 2px 8px rgba(var(--black), 5%);
	}
	h2 {
		margin: 0;
		font-size: 1em;
	}
	.logo {
		font-family: 'Fraunces', Georgia, serif;
		font-weight: 700;
		font-size: 22px;
		color: #1C1A17;
		text-decoration: none;
	}
	.logo span {
		color: #C5613A;
	}
	.logo:hover {
		text-decoration: none;
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 16px;
	}
	nav a.active {
		text-decoration: none;
		border-bottom-color: var(--accent);
	}
	.internal-links a {
		padding: 0.6em 0.5em;
		color: var(--black);
		border-bottom: 4px solid transparent;
		text-decoration: none;
	}
	.right-side {
		display: flex;
		align-items: center;
		gap: 12px;
	}
	.eligibility-btn {
		background: #C5613A;
		color: #fff;
		font-size: 13px;
		font-weight: 700;
		padding: 8px 16px;
		border-radius: 6px;
		text-decoration: none;
		white-space: nowrap;
		flex-shrink: 0;
	}
	.eligibility-btn:hover {
		background: #B5532F;
	}
	.menu-toggle {
		display: none;
		background: none;
		border: none;
		font-size: 22px;
		color: #1C1A17;
		cursor: pointer;
		padding: 4px 8px;
	}
	.mobile-links {
		display: none;
		flex-direction: column;
		padding: 12px 1em 16px;
		border-top: 1px solid #EEE9E0;
	}
	.mobile-links a {
		padding: 12px 0;
		color: #1C1A17;
		text-decoration: none;
		font-size: 15px;
		border-bottom: 1px solid #F5F0E8;
	}
	.mobile-links.open {
		display: flex;
	}
	@media (max-width: 720px) {
		.internal-links {
			display: none;
		}
		.menu-toggle {
			display: block;
		}
	}
</style>