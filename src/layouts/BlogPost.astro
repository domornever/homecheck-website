---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage } = Astro.props;
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
		<style>
			* {
				box-sizing: border-box;
			}
			main {
				width: calc(100% - 2em);
				max-width: 100%;
				margin: 0;
				flex: 1;
			}
			.hero-image {
				width: 100%;
			}
			.hero-image img {
				display: block;
				margin: 0 auto;
				border-radius: 12px;
				box-shadow: var(--box-shadow);
			}
			.prose {
				width: 720px;
				max-width: calc(100% - 2em);
				margin: auto;
				padding: 2em 1em 4em;
				color: #3A3733;
				font-family: system-ui, -apple-system, 'Segoe UI', Roboto, Arial, sans-serif;
				font-size: 16px;
				line-height: 1.7;
			}
			.title {
				margin-bottom: 1.5em;
				padding: 1.5em 0 0;
				text-align: center;
				line-height: 1;
			}
			.title h1 {
				font-family: Georgia, serif;
				font-size: clamp(28px, 5vw, 40px);
				font-weight: 700;
				color: #1C1A17;
				margin: 0 0 0.5em 0;
				line-height: 1.2;
			}
			.date {
				margin-bottom: 0.5em;
				font-size: 12px;
				font-weight: 700;
				letter-spacing: 0.6px;
				text-transform: uppercase;
				color: #9A8C77;
			}
			.last-updated-on {
				font-style: italic;
			}
			.title hr {
				border: none;
				border-top: 1px solid #EEE9E0;
				margin-top: 1.5em;
			}

			/* ── Markdown content typography ─────────────────────────────── */
			.prose :global(h2) {
				font-family: Georgia, serif;
				font-size: 26px;
				font-weight: 700;
				color: #1C1A17;
				margin: 1.6em 0 0.6em;
				line-height: 1.3;
			}
			.prose :global(h3) {
				font-family: Georgia, serif;
				font-size: 20px;
				font-weight: 700;
				color: #1C1A17;
				margin: 1.4em 0 0.5em;
				line-height: 1.3;
			}
			.prose :global(p) {
				margin: 0 0 1.2em;
			}
			.prose :global(strong) {
				font-weight: 700;
				color: #1C1A17;
			}
			.prose :global(em) {
				font-style: italic;
			}
			.prose :global(a) {
				color: #C5613A;
				text-decoration: underline;
				text-decoration-thickness: 1px;
				text-underline-offset: 2px;
			}
			.prose :global(a:hover) {
				color: #B5532F;
			}
			.prose :global(ul),
			.prose :global(ol) {
				margin: 0 0 1.2em;
				padding-left: 1.4em;
			}
			.prose :global(li) {
				margin-bottom: 0.5em;
			}
			.prose :global(blockquote) {
				margin: 1.5em 0;
				padding: 0.2em 0 0.2em 1.2em;
				border-left: 3px solid #C5613A;
				font-style: italic;
				color: #5A5040;
			}

			/* ── Tables ───────────────────────────────────────────────────── */
			.prose :global(table) {
				width: 100%;
				border-collapse: collapse;
				margin: 1.6em 0;
				font-size: 14px;
			}
			.prose :global(th) {
				background: #F7F4EE;
				color: #1C1A17;
				font-weight: 700;
				text-align: left;
				padding: 10px 14px;
				border: 1px solid #E8E0D3;
			}
			.prose :global(td) {
				padding: 10px 14px;
				border: 1px solid #E8E0D3;
				color: #3A3733;
			}
			.prose :global(tr:nth-child(even) td) {
				background: #FAF7F2;
			}

			/* ── Code ─────────────────────────────────────────────────────── */
			.prose :global(code) {
				background: #F7F4EE;
				padding: 2px 6px;
				border-radius: 4px;
				font-size: 14px;
			}
			.prose :global(hr) {
				border: none;
				border-top: 1px solid #EEE9E0;
				margin: 2em 0;
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article>
				<div class="hero-image">
					{heroImage && <Image width={1020} height={510} src={heroImage} alt="" />}
				</div>
				<div class="prose">
					<div class="title">
						<div class="date">
							<FormattedDate date={pubDate} />
							{
								updatedDate && (
									<div class="last-updated-on">
										Last updated on <FormattedDate date={updatedDate} />
									</div>
								)
							}
						</div>
						<h1>{title}</h1>
						<hr />
					</div>
					<slot />
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>